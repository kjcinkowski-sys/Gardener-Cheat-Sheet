# Gardener Cheat Sheet — production environment variables (API).
# Set these in your host's dashboard (e.g. Render). Nested config keys use double underscores.
# Do NOT commit real values.

# --- Database (Neon or any Postgres) ---
# Npgsql format. Managed Postgres requires SSL.
ConnectionStrings__Default=Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<pass>;SSL Mode=Require;Trust Server Certificate=true

# --- Trefle plant API ---
Trefle__Token=<your-trefle-api-token>

# --- CORS: the deployed frontend origin (Vercel URL). Add more with __1, __2, ... ---
Cors__AllowedOrigins__0=https://<your-frontend>.vercel.app

# --- Photo storage: object store (Cloudflare R2 / AWS S3) ---
Storage__Provider=S3
Storage__S3__ServiceUrl=https://<account-id>.r2.cloudflarestorage.com
Storage__S3__Bucket=<bucket-name>
Storage__S3__AccessKey=<r2-access-key-id>
Storage__S3__SecretKey=<r2-secret-access-key>
Storage__S3__PublicBaseUrl=https://<your-bucket-public-url>   # e.g. https://pub-xxxx.r2.dev
Storage__S3__Region=auto

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Production
